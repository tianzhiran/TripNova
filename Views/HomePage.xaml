<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TripNova.Views.HomePage"
    Title="Home"
    BackgroundColor="#F4F6FA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Hero -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Plan Your Dream Trip"
                       FontSize="28"
                       FontAttributes="Bold"/>

                <Label Text="Everything you need for the perfect journey."
                       FontSize="14"
                       TextColor="Gray"/>
            </VerticalStackLayout>

            <!-- Quick Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                <Button Grid.Column="0"
                        Text="Search"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="OnSearchTapped"/>

                <Button Grid.Column="1"
                        Text="Ask AI"
                        BackgroundColor="#7C3AED"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="OnAITapped"/>
            </Grid>

            <Label Text="Trip Planning Tools"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <!-- Cards -->
            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="15"
                  RowSpacing="15">

                <!-- Search -->
                <Border Grid.Row="0" Grid.Column="0"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🔍" FontSize="24"/>
                        <Label Text="Search Destinations" FontAttributes="Bold"/>
                        <Label Text="Discover cities &amp; attractions"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Budget -->
                <Border Grid.Row="0" Grid.Column="1"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBudgetTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="💰" FontSize="24"/>
                        <Label Text="Budget Planner" FontAttributes="Bold"/>
                        <Label Text="Track travel expenses easily"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Transport -->
                <Border Grid.Row="1" Grid.Column="0"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTransportTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="✈️" FontSize="24"/>
                        <Label Text="Transportation" FontAttributes="Bold"/>
                        <Label Text="Find flights &amp; routes"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Accommodation -->
                <Border Grid.Row="1" Grid.Column="1"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAccommodationTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🏨" FontSize="24"/>
                        <Label Text="Accommodation" FontAttributes="Bold"/>
                        <Label Text="Book hotels &amp; stays"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Food -->
                <Border Grid.Row="2" Grid.Column="0"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFoodTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🍽️" FontSize="24"/>
                        <Label Text="Food &amp; Dining" FontAttributes="Bold"/>
                        <Label Text="Explore local cuisine"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Itinerary -->
                <Border Grid.Row="2" Grid.Column="1"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnItineraryTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅" FontSize="24"/>
                        <Label Text="Itinerary" FontAttributes="Bold"/>
                        <Label Text="Plan your day-by-day trip"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- AI -->
                <Border Grid.Row="3" Grid.Column="0"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAITapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🤖" FontSize="24"/>
                        <Label Text="AI Assistant" FontAttributes="Bold"/>
                        <Label Text="Get smart travel suggestions"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Trips -->
                <Border Grid.Row="3" Grid.Column="1"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTripsTapped"/>
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🧳" FontSize="24"/>
                        <Label Text="My Trips" FontAttributes="Bold"/>
                        <Label Text="Manage your saved journeys"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>