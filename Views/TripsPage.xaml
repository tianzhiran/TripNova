<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TripNova.Views.TripsPage"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Spacing="15">

            <!-- 🔴 HEADER -->
            <Grid HeightRequest="160" Padding="20" BackgroundColor="#FF2D75">
                <VerticalStackLayout Spacing="10">

                    <Label Text="My Trips"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Manage all your travel plans"
                           FontSize="14"
                           TextColor="White"/>

                    <Button Text="+ Plan New Trip"
                            Command="{Binding GoToCreateTripCommand}"
                            BackgroundColor="White"
                            TextColor="#FF2D75"
                            CornerRadius="10"
                            HeightRequest="45"/>
                </VerticalStackLayout>
            </Grid>

            <!-- 🔘 FILTER TABS (FIXED) -->
            <HorizontalStackLayout Spacing="10" Padding="15,0">

                <Button Text="All Trips"
                        Command="{Binding FilterCommand}"
                        CommandParameter="All"
                        BackgroundColor="#FF2D75"
                        TextColor="White"
                        CornerRadius="20"/>

                <Button Text="Upcoming"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Upcoming"
                        BackgroundColor="#E0E0E0"
                        CornerRadius="20"/>

                <Button Text="Happening"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Happening"
                        BackgroundColor="#E0E0E0"
                        CornerRadius="20"/>

                <Button Text="Past"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Past"
                        BackgroundColor="#E0E0E0"
                        CornerRadius="20"/>
            </HorizontalStackLayout>

            <!-- 📦 TRIPS LIST -->
            <CollectionView ItemsSource="{Binding Trips}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeShape="RoundRectangle 15"
                                Margin="15,5"
                                Padding="0"
                                BackgroundColor="White">

                            <VerticalStackLayout>

                                <!-- IMAGE -->
                                <Grid HeightRequest="150">
                                    <Image Source="bali.jpg"
                                           Aspect="AspectFill"/>

                                    <Label Text="{Binding Status}"
                                           BackgroundColor="#DDE7FF"
                                           TextColor="{Binding StatusColor}"
                                           Padding="6,2"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="10"/>
                                </Grid>

                                <!-- CONTENT -->
                                <VerticalStackLayout Padding="12" Spacing="6">

                                    <Label Text="{Binding Destination}"
                                           FontSize="18"
                                           FontAttributes="Bold"/>

                                   

                                    <!-- Date + Budget -->
                                    <Grid ColumnDefinitions="*,*">

                                        <Label>
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding StartDate, StringFormat='{0:MMM dd}'}"/>
                                                    <Span Text=" - "/>
                                                    <Span Text="{Binding EndDate, StringFormat='{0:MMM dd}'}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <Label Text="{Binding Budget, StringFormat='$ {0}'}"
                                               Grid.Column="1"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>

                                    <Label Text="{Binding Travellers, StringFormat='{0} travelers'}"
                                           FontSize="12"
                                           TextColor="Gray"/>

                                    <Border BackgroundColor="#EEF2FF"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="8">
                                        <Label Text="{Binding CountdownText}"
                                               HorizontalTextAlignment="Center"
                                               TextColor="#3B82F6"/>       
                                    </Border>

                                    <!-- ACTIONS (FIXED) -->
                                    <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">

                                        <!-- Edit (optional) -->
                                        <Button Text="Edit"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTripCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#F5F5F5"
                                                Grid.Column="0"/>

                                        <!-- DELETE (FIXED 🔥) -->
                                        <Button Text="Delete"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTripCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#FFE5E5"
                                                TextColor="Red"
                                                Grid.Column="1"/>
                                    </Grid>

                                </VerticalStackLayout>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>